//!Visual Calculation
//Use visual calculation for conditional formatting instead of a measure
Color =
VAR AvgValue =
    AVERAGEX ( ROWS, [Sales Amount] )
VAR Result =
    IF ( [Sales Amount] >= AvgValue, "Green", "Red" )
RETURN
    Result
